rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.role == 'admin';
    }

    function isMartManager() {
      return signedIn() && request.auth.token.role == 'martManager';
    }

    function isApproved() {
      return resource.data.approvalStatus == 'approved';
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /marts/{martId} {
      allow read: if resource.data.status == 'open' || isAdmin() || isMartManager();
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /price_items/{priceItemId} {
      allow read: if isApproved() || isAdmin() || isMartManager();
      allow create, update, delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isOwner(resource.data.reporterId) || isAdmin();
      allow create: if signedIn() && request.resource.data.reporterId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /points/{pointId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow write: if isAdmin();
    }

    match /shopping_memos/{memoId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /receipts/{receiptId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /recipes/{recipeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create, update, delete: if isAdmin();
    }
  }
}
